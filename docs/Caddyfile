# === IP-based fallback (no domain required) ===
# Aktif ketika VPS diakses langsung via IP 104.207.73.54
# Semua service lain tetap di port masing-masing (8001-8003, 8011-8018, 3000)
http:// {
	root * /var/www/landing
	encode gzip zstd
	try_files {path} /index.html
	file_server
	header {
		-Server
		-X-Powered-By
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	log {
		output file /var/log/caddy-extra/landing.log {
			roll_size 50mb
			roll_keep 5
		}
	}
}
